{
  "name": "tracelane-demo",
  "version": "0.0.0",
  "private": true,
  "description": "QA fixture for @tracelane/wdio — runs a passing and a failing WDIO spec to validate the failed-only HTML report.",
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "test:pass": "wdio run wdio.conf.ts --spec tests/passing.spec.ts",
    "test:fail": "wdio run wdio.conf.ts --spec tests/failing.spec.ts"
  },
  "devDependencies": {
    "@tracelane/core": "^0.1.0-alpha.2",
    "@tracelane/report": "^0.1.0-alpha.2",
    "@tracelane/wdio": "^0.1.0-alpha.2",
    "@types/node": "^22.10.0",
    "@wdio/cli": "^9.0.0",
    "@wdio/globals": "^9.0.0",
    "@wdio/local-runner": "^9.0.0",
    "@wdio/mocha-framework": "^9.0.0",
    "@wdio/spec-reporter": "^9.0.0",
    "@wdio/types": "^9.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.2",
    "webdriverio": "^9.0.0"
  }
}
