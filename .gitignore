# Astro (apps/*-docs) — generated content-types + build cache.
.astro/
# Maintainer's local hand-copy of the built peek extension (the canonical
# build output is at packages/peek-extension/.output/ which `.output/` above
# already catches; this entry guards against an additional copy that gets
# manually rsynced next to the package source for chrome://extensions loads).
# Without this, lefthook biome chokes trying to lint the bundled minified
# output on every commit.
packages/peek-extension/chrome-mv3/
.DS_Store
.idea/
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
coverage/
*.log
# Playwright (peek-extension/e2e/) — `test:e2e` writes these on every run.
test-results/
playwright-report/
.playwright/
.env
.env.*
!.env.example
.changeset/.cache/
# Maintainer-private docs that don't belong in the public repo. Things like
# the operational launch plan (contact lists, day-90 thresholds, anti-pattern
# floor) and the personal-blog draft for harish.dev. The repo went public on
# 2026-05-29; this directory was added 2026-05-30 to host the docs that
# moved out of `docs/` in the audit-cleanup pass. Anything dropped here
# stays on the maintainer's machine and is never committed.
docs-private/
