# Astro (apps/*-docs) — generated content-types + build cache.
.astro/
# Maintainer's local hand-copy of the built peek extension (the canonical
# build output is at packages/peek-extension/.output/ which `.output/` above
# already catches; this entry guards against an additional copy that gets
# manually rsynced next to the package source for chrome://extensions loads).
# Without this, lefthook biome chokes trying to lint the bundled minified
# output on every commit.
packages/peek-extension/chrome-mv3/
.DS_Store
.idea/
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
coverage/
*.log
# Playwright (peek-extension/e2e/) — `test:e2e` writes these on every run.
test-results/
playwright-report/
.playwright/
.env
.env.*
!.env.example
.changeset/.cache/
# Symlink to the maintainer-private companion repo (Cubenest/rrweb-stack-private)
# documented in CLAUDE.md. Convention: clone both repos as siblings on the dev
# machine + `ln -s ../rrweb-stack-private _context`. The symlink lives in the
# working tree but is never tracked. CI runners + contributors without access
# see a dangling symlink and gracefully degrade.
_context
_context/
# (Pre-_context/ migration) Previously used local-only directory for the same
# launch plan + origin-story content. Now lives in the companion repo at
# `_context/docs/`. Pattern retained so any leftover local copies stay
# untracked.
docs-private/
