    "changeset": "changeset",
    "release": "pnpm build && changeset publish"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@changesets/cli": "^2.27.10",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8",
    "lefthook": "^1.10.10"
  }
}
