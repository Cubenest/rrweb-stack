{
  "name": "rrweb-stack",
  "version": "0.0.0",
  "private": true,
  "description": "Two-product OSS initiative: tracelane + peek.",
  "license": "Apache-2.0",
  "packageManager": "pnpm@9.14.4",
  "engines": { "node": ">=20.10.0" },
  "scripts": {
    "build": "pnpm -r build",
