{
  "name": "@cubenest/docs-shared",
  "version": "0.0.0",
  "private": true,
  "description": "Shared types and schemas for the tracelane-docs and peek-docs Astro apps.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "verify-recipes": "pnpm run build && node scripts/verify-recipes.mjs",
    "verify-recipes:live": "pnpm run build && node scripts/verify-recipes-live.mjs",
    "verify-recipes:wdio": "node scripts/verify-recipes-wdio.mjs",
    "gen:security-demo": "node scripts/gen-security-demo.mjs"
  },
  "dependencies": {
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cubenest/rrweb-core": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@tracelane/report": "workspace:*",
    "js-yaml": "^4.1.1",
    "playwright": "^1.61.1"
  }
}
