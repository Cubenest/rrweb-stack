{
  "name": "@cubenest/rrweb-core",
  "version": "0.1.0-alpha.4",
  "description": "Shared rrweb-based capture substrate for tracelane and peek.",
  "keywords": [
    "rrweb",
    "session-replay",
    "browser-recording",
    "dom-capture",
    "posthog-rrweb-fork",
    "masking",
    "capture-substrate"
  ],
  "license": "Apache-2.0",
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/harry-harish"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "NOTICE", "README.md"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@posthog/rrweb": "0.0.34",
    "@posthog/rrweb-types": "0.0.24",
    "@rrweb/rrweb-plugin-console-record": "2.0.0-alpha.20",
    "fflate": "^0.8.2"
  },
  "devDependencies": {
    "jsdom": "^25.0.1",
    "fake-indexeddb": "^6.0.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Cubenest/rrweb-stack",
    "directory": "packages/rrweb-core"
  },
  "bugs": { "url": "https://github.com/Cubenest/rrweb-stack/issues" },
  "homepage": "https://github.com/Cubenest/rrweb-stack/tree/main/packages/rrweb-core#readme",
  "engines": { "node": ">=20.18.0" }
}
