{
  "name": "@peekdev/extension",
  "version": "0.1.0-alpha.19",
  "description": "peek Chrome MV3 extension: side panel UI, per-site activation, MAIN-world rrweb recorder, and the native-messaging bridge that keeps the service worker alive (ADR-0008, ADR-0009). Loaded unpacked by alpha testers; not published to npm.",
  "license": "Apache-2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "build": "wxt build && pnpm assert:recorder-iife",
    "assert:recorder-iife": "node scripts/assert-recorder-iife.mjs",
    "generate:icons": "node scripts/generate-icons.mjs",
    "zip": "wxt zip",
    "typecheck": "wxt prepare && tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:e2e": "playwright test -c e2e/playwright.config.ts",
    "postinstall": "wxt prepare"
  },
  "dependencies": {
    "@cubenest/rrweb-core": "workspace:*",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/chrome": "^0.2.0",
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.29",
    "@types/react-dom": "^18.3.7",
    "@webext-core/fake-browser": "^1.5.2",
    "@wxt-dev/module-react": "^1.2.2",
    "better-sqlite3": "^12.11.1",
    "esbuild": "^0.28.1",
    "jsdom": "^25.0.1",
    "sharp": "^0.35.2",
    "vite": "^6.4.2",
    "wxt": "^0.20.27"
  }
}
