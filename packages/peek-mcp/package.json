{
  "name": "@peekdev/mcp",
  "version": "0.1.0-alpha.2",
  "description": "peek native messaging host + stdio MCP server. Owns ~/.peek/sessions.db (better-sqlite3) and bridges the browser extension, CLI, and AI tools to a single local source of truth (ADR-0007).",
  "license": "Apache-2.0",
  "type": "module",
  "bin": {
    "peek-mcp": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./db": {
      "types": "./dist/db/index.d.ts",
      "import": "./dist/db/index.js"
    },
    "./native-host": {
      "types": "./dist/native-host/index.d.ts",
      "import": "./dist/native-host/index.js"
    }
  },
  "files": [
    "dist",
    "scripts/postinstall-guard.mjs",
    "src/db/migrations",
    "src/native-host/extension-ids.json",
    "NOTICE",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && node ./scripts/postbuild.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests",
    "postinstall": "node ./scripts/postinstall-guard.mjs"
  },
  "dependencies": {
    "@cubenest/rrweb-core": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^12.10.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Cubenest/rrweb-stack",
    "directory": "packages/peek-mcp"
  },
  "homepage": "https://github.com/Cubenest/rrweb-stack/tree/main/packages/peek-mcp#readme"
}
