{
  "name": "@tracelane/report",
  "version": "0.1.0-alpha.9",
  "description": "Self-contained, offline HTML report builder for tracelane. Embeds the rrweb player and a gzipped event blob into a single .html file.",
  "keywords": ["tracelane", "html-report", "rrweb", "session-replay", "testing", "offline"],
  "license": "Apache-2.0",
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/harry-harish"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "NOTICE", "README.md"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@cubenest/rrweb-core": "workspace:*",
    "@fontsource-variable/fraunces": "^5.2.7",
    "@fontsource-variable/jetbrains-mono": "^5.2.7",
    "@tracelane/core": "workspace:*",
    "fflate": "^0.8.2",
    "rrweb-player": "1.0.0-alpha.4"
  },
  "devDependencies": {
    "jsdom": "^25.0.1"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Cubenest/rrweb-stack",
    "directory": "packages/tracelane-report"
  },
  "homepage": "https://github.com/Cubenest/rrweb-stack/tree/main/packages/tracelane-report#readme"
}
