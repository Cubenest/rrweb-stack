{
  "name": "@tracelane/cli",
  "version": "0.1.0-alpha.14",
  "description": "tracelane scaffolding CLI. `npx @tracelane/cli init` detects your test runner (WDIO / Playwright / Cypress) and wires the matching adapter (@tracelane/wdio or @tracelane/playwright) into your runner config in one command — the published path from `npm install` + manual conf edit to a single npx invocation.",
  "keywords": [
    "tracelane",
    "testing",
    "e2e",
    "webdriverio",
    "playwright",
    "cypress",
    "init",
    "scaffold"
  ],
  "license": "Apache-2.0",
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/harry-harish"
  },
  "type": "module",
  "bin": {
    "tracelane": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "NOTICE", "README.md"],
  "scripts": {
    "build": "tsc -p tsconfig.json && node ./scripts/postbuild.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^22.10.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Cubenest/rrweb-stack",
    "directory": "packages/tracelane-cli"
  },
  "bugs": {
    "url": "https://github.com/Cubenest/rrweb-stack/issues"
  },
  "homepage": "https://tracelane.cubenest.in",
  "engines": {
    "node": ">=22"
  }
}
