{
  "mcpServers": {
    "peek": {
      "command": "npx",
      "args": ["-y", "@peekdev/mcp@latest"]
    },
    "peek-dev": {
      "command": "node",
      "args": ["${CLAUDE_PROJECT_DIR:-.}/packages/peek-mcp/dist/index.js"]
    },
    "peek-dev-src": {
      "command": "${CLAUDE_PROJECT_DIR:-.}/node_modules/.bin/tsx",
      "args": ["${CLAUDE_PROJECT_DIR:-.}/packages/peek-mcp/src/index.ts"]
    }
  }
}
