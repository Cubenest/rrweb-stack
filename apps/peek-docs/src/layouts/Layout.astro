---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'peek — open-source, local-first. Turns a recorded browser session into a Playwright repro your AI coding agent can re-run to verify its own fix. Redacted by default, no cloud.' } = Astro.props;

// Build absolute canonical / social URLs from the configured `site` origin.
const canonicalURL = new URL(Astro.url.pathname, Astro.site).href;
const ogImageURL = new URL('/og-card.png', Astro.site).href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:site_name" content="peek" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />
    <title>{title}</title>
    <!-- Vercel Web Analytics — cookieless page metrics for the docs site only (the products ship no telemetry) -->
    <script is:inline>
      window.va =
        window.va ||
        function () {
          (window.vaq = window.vaq || []).push(arguments);
        };
    </script>
    <script is:inline defer src="/_vercel/insights/script.js"></script>
  </head>
  <body>
    <header class="site-header">
      <div class="inner">
        <a href="/" class="brand">peek</a>
        <nav>
          <a href="/">Home</a>
          <a href="/getting-started">Getting started</a>
          <a href="/recipes">Recipes</a>
          <a href="/vs-jam-dev">vs Jam.dev</a>
          <a href="/vs-browser-mcp">vs Browser MCP</a>
          <a href="/vs-sentry-spotlight">vs Sentry Spotlight</a>
          <a href="/privacy">Privacy</a>
          <a href="https://github.com/Cubenest/rrweb-stack" rel="noopener">GitHub</a>
        </nav>
      </div>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <div class="inner">
        <span>Apache 2.0 &middot; local-first &middot; <a href="https://github.com/Cubenest/rrweb-stack" rel="noopener">Cubenest/rrweb-stack</a></span>
        <span>Alpha software &mdash; APIs may shift before 1.0.</span>
      </div>
    </footer>
  </body>
</html>
