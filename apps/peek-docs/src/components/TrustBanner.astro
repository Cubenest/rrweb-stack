---
// Rendered unconditionally inside RecipeLayout for every peek recipe. The
// audience is rightly cautious about AI agents touching authenticated
// browsers; the trust framing leads, doesn't hide.
---

<aside class="trust-banner" aria-label="peek trust and data handling summary">
  <span class="dot" aria-hidden="true"></span>
  <p>
    <strong>Runs in your local Chrome.</strong>
    Per-action authorization required. Data stays on your machine.
    <a href="/privacy">Privacy &amp; data handling &rarr;</a>
  </p>
</aside>

<style>
  .trust-banner {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin: 1rem 0 1.5rem;
    padding: 0.75rem 1rem;
    border: 1px solid var(--accent);
    border-radius: 6px;
    background: rgba(30, 111, 217, 0.06);
  }
  .trust-banner .dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--accent);
    flex-shrink: 0;
  }
  .trust-banner p { margin: 0; font-size: 0.85rem; line-height: 1.5; }
  .trust-banner a { color: var(--accent); white-space: nowrap; }
</style>
